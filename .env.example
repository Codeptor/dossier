# Last.fm API key — used to populate the "Listening" row on /now with the
# most recently played track. Grab one at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Upstash Redis — stores live phone-GPS pings for /now's Location row.
# Provision via Vercel Marketplace → Upstash Redis. The integration auto-fills
# KV_REST_API_URL + KV_REST_API_TOKEN in Vercel envs; only set them here for
# local dev (or leave blank to fall back to the static "India · IST." label).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Shared secret for POST /api/location/ingest. The Android shortcut sends this
# as `Authorization: Bearer <secret>`. Generate with `openssl rand -hex 32`.
LOCATION_INGEST_SECRET=
