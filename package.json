{
  "name": "codeptor-dossier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "fetch:activity": "tsx scripts/fetch-activity.ts",
    "fetch:commits": "tsx scripts/fetch-commits.ts",
    "prebuild": "pnpm run fetch:activity && pnpm run fetch:commits",
    "build": "astro check && astro build && pagefind --site dist/client --output-subdir _pagefind",
    "preview": "astro preview --host 0.0.0.0"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^9.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "astro": "^5.15.6",
    "pagefind": "^1.5.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0"
  }
}
