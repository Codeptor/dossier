---
import Barcode from "@/components/Barcode.astro";
import { artifacts, profile } from "@/data/profile";

interface Props {
  state: "active" | "left" | "right";
  route?: string;
}

const { state, route = "/artifacts" } = Astro.props;
const total = artifacts.length;
---

<article
  class:list={["sheet", "archive-sheet", state]}
  data-sheet="artifacts"
  data-route={route}
  transition:name="sheet-archive"
>
  <div class="paper-grain"></div>
  <div class="blue-grid"></div>
  <svg class="distance-rings" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
    <circle cx="50" cy="50" r="20" />
    <circle cx="50" cy="50" r="32" />
    <circle cx="50" cy="50" r="44" />
    <circle cx="50" cy="50" r="56" />
  </svg>
  <header class="archive-head">
    <span>Spec_Archive</span>
    <h1>System_Archive</h1>
    <p>Registry_Index // Artifacts</p>
    <small>Vol. 2026.01</small>
    <div class="archive-stat-row">
      <div class="archive-stat">
        <span>Date</span>
        <strong>Wed, Apr 29, 2026</strong>
      </div>
      <div class="archive-stat">
        <span>Log_Time</span>
        <strong>05:12 AM</strong>
      </div>
      <div class="archive-stat">
        <span>Status</span>
        <strong>Verified</strong>
      </div>
    </div>
  </header>

  <section class="registry">
    <h2>
      <i></i>
      <span class="registry-title">Experimental_Registry</span>
      <em class="registry-count">· {String(total).padStart(2, "0")}</em>
    </h2>
    <div class="artifact-list">
      {artifacts.map((artifact) => (
        <a href={artifact.href}>
          <div>
            <strong>{artifact.name}</strong>
            <p>{artifact.description}</p>
            <em>{artifact.href}</em>
          </div>
          <span>{artifact.year}</span>
        </a>
      ))}
    </div>
  </section>

  <footer class="archive-foot">
    <div>
      <span>Authorization</span>
      <svg viewBox="0 0 260 80" aria-hidden="true" class="constellation">
        <g class="constellation-lines">
          <polyline points="22,58 56,42 92,52 128,28 162,40 198,22 232,32" />
          <polyline points="56,42 78,68 128,28" />
          <polyline points="162,40 184,62 232,32" />
        </g>
        <g class="constellation-stars">
          <circle cx="22" cy="58" r="2.2" />
          <circle cx="56" cy="42" r="3" />
          <circle cx="78" cy="68" r="1.8" />
          <circle cx="92" cy="52" r="1.6" />
          <circle cx="128" cy="28" r="3.4" />
          <circle cx="162" cy="40" r="2.6" />
          <circle cx="184" cy="62" r="1.8" />
          <circle cx="198" cy="22" r="2" />
          <circle cx="232" cy="32" r="2.4" />
        </g>
      </svg>
    </div>
    <div>
      <span>Checksum</span>
      <strong>{profile.checksum}</strong>
      <Barcode />
    </div>
    <p>*** No_Further_Data ***</p>
  </footer>
</article>
