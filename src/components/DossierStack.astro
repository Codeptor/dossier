---
import ArchiveSheet from "@/components/ArchiveSheet.astro";
import ManifestSheet from "@/components/ManifestSheet.astro";
import Nav from "@/components/Nav.astro";
import ThoughtsSheet from "@/components/ThoughtsSheet.astro";
import { profile } from "@/data/profile";

interface Props {
  active: "home" | "thoughts" | "artifacts";
}

const { active } = Astro.props;

type Sheet = "home" | "thoughts" | "artifacts";
type SheetState = "active" | "left" | "right";

const stateFor = (sheet: Sheet): SheetState => {
  if (sheet === active) return "active";
  const positions: Record<Sheet, Record<Exclude<Sheet, typeof active>, SheetState>> = {
    home: { thoughts: "right", artifacts: "left" },
    thoughts: { home: "left", artifacts: "right" },
    artifacts: { thoughts: "left", home: "right" },
  };
  return positions[active][sheet as Exclude<Sheet, typeof active>];
};
---

<Nav active={active} />
<main id="content" class="site-shell" tabindex="-1">
  <div class="stack-wrap" data-active={active}>
    <ManifestSheet state={stateFor("home")} route="/" />
    <ThoughtsSheet state={stateFor("thoughts")} route="/thoughts" />
    <ArchiveSheet state={stateFor("artifacts")} route="/artifacts" />
  </div>
</main>

<footer class="site-foot">
  <span>© {profile.year}</span>
  <nav aria-label="Feed">
    <a href="/rss.xml">rss feed</a>
  </nav>
</footer>

<script>
  import { swap as swapSound } from "@/lib/audio";

  const routes = ["/", "/thoughts", "/artifacts"];
  const sheetForRoute: Record<string, string> = {
    "/": "manifest",
    "/thoughts": "thoughts",
    "/artifacts": "artifacts",
  };
  // Maps the data-sheet identifier to its view-transition-name.
  const groupName: Record<string, string> = {
    manifest: "sheet-manifest",
    thoughts: "sheet-thoughts",
    artifacts: "sheet-archive",
  };

  const STYLE_ID = "sheet-target-style";

  // Browsers don't honour `html[attr] ::view-transition-group(name)` selectors
  // — the attribute filter doesn't propagate to view-transition pseudo-elements.
  // Inject a hard-coded rule via a managed <style> tag so the becoming-active
  // sheet's group renders on top of the others during the morph.
  const setTargetSheet = (sheetId: string | null) => {
    let tag = document.getElementById(STYLE_ID) as HTMLStyleElement | null;
    if (!tag) {
      tag = document.createElement("style");
      tag.id = STYLE_ID;
      document.head.appendChild(tag);
    }
    if (!sheetId || !groupName[sheetId]) {
      tag.textContent = "";
      return;
    }
    tag.textContent = `::view-transition-group(${groupName[sheetId]}) { z-index: 100 !important; }`;
  };

  const currentRoute = () => {
  const path = window.location.pathname.replace(/\/$/, "") || "/";
    if (path.startsWith("/thoughts")) return "/thoughts";
    if (path.startsWith("/artifacts")) return "/artifacts";
    return routes.includes(path) ? path : "/";
  };

  const go = (route: string) => {
    if (route === currentRoute()) return;
    setTargetSheet(sheetForRoute[route]);
    // Set --swap-dir for the mobile slide animation; harmless on desktop where
    // a different keyframe set is in play.
    const cur = routes.indexOf(currentRoute());
    const target = routes.indexOf(route);
    if (cur !== -1 && target !== -1) {
      const dir = target > cur ? 1 : -1;
      document.documentElement.style.setProperty("--swap-dir", String(dir));
    }
    const link = document.querySelector<HTMLAnchorElement>(`a[href="${route}"]`);
    if (link) {
      link.click();
      return;
    }
    window.location.href = route;
  };

  // AbortController bound to the lifetime of the current page. On every
  // astro:page-load we abort the previous controller (removing all of its
  // attached listeners) and create a fresh one — guarantees no listener
  // accumulation across view-transition swaps and no stale closures
  // referencing previously-active sheets.
  let controlsAbort: AbortController | null = null;

  const attachSheetControls = () => {
    controlsAbort?.abort();
    controlsAbort = new AbortController();
    const { signal } = controlsAbort;

    const sheets = Array.from(document.querySelectorAll<HTMLElement>("[data-sheet][data-route]"));
    const active = document.querySelector<HTMLElement>(".sheet.active");
    const activeRoute = currentRoute();

    sheets.forEach((sheet) => {
      sheet.addEventListener(
        "click",
        (event) => {
          if (sheet.classList.contains("active")) return;
          const target = event.target as HTMLElement;
          if (target.closest("a")) return;
          go(sheet.dataset.route || "/");
        },
        { signal },
      );
    });

    if (!active) return;

    let startX = 0;
    let startY = 0;
    let dragging = false;
    let pointerId = 0;
    let lockedHorizontal = false;

    active.addEventListener(
      "pointerdown",
      (event) => {
        const target = event.target as HTMLElement;
        if (target.closest("a, button")) return;
        // Don't preventDefault here — that blocks native vertical scroll on
        // touch. We let touch-action: pan-y on the sheet handle scroll
        // disambiguation; once we detect a horizontal-dominant gesture in
        // pointermove we lock the drag and capture the pointer.
        pointerId = event.pointerId;
        startX = event.clientX;
        startY = event.clientY;
        dragging = true;
        lockedHorizontal = false;
      },
      { signal },
    );

    active.addEventListener(
      "pointermove",
      (event) => {
        if (!dragging || event.pointerId !== pointerId) return;
        const dx = event.clientX - startX;
        const dy = event.clientY - startY;

        if (!lockedHorizontal) {
          if (Math.abs(dx) < 6 && Math.abs(dy) < 6) return;
          if (Math.abs(dy) > Math.abs(dx)) {
            dragging = false;
            return;
          }
          lockedHorizontal = true;
          active.classList.add("dragging");
          try {
            active.setPointerCapture(pointerId);
          } catch (_) {}
        }

        event.preventDefault();
        active.style.setProperty("--drag-x", `${dx}px`);
      },
      { signal },
    );

    const release = (event: PointerEvent) => {
      if (!dragging || event.pointerId !== pointerId) return;
      const dx = event.clientX - startX;
      dragging = false;
      const wasHorizontal = lockedHorizontal;
      lockedHorizontal = false;
      active.classList.remove("dragging");
      if (!wasHorizontal) return;

      const index = routes.indexOf(activeRoute);
      const passed = Math.abs(dx) > 120;

      if (passed) {
        const direction = dx > 0 ? 1 : -1;
        const nextIndex = (index + direction + routes.length) % routes.length;
        const nextRoute = routes[nextIndex];
        document.documentElement.style.setProperty("--swap-dir", String(direction));
        swapSound();
        go(nextRoute);
      } else {
        active.style.removeProperty("--drag-x");
      }
    };

    active.addEventListener("pointerup", release, { signal });
    active.addEventListener("pointercancel", release, { signal });
  };

  attachSheetControls();

  // Astro replaces <head> during the DOM swap, which blows away our
  // dynamic <style id="sheet-target-style"> tag. Re-inject it at swap
  // boundaries pointing at the destination's active sheet so the
  // view-transition animation keeps the right z-index override.
  document.addEventListener("astro:before-swap", (event: any) => {
    const newActive = event?.newDocument
      ?.querySelector(".sheet.active")
      ?.dataset?.sheet;
    if (newActive) setTargetSheet(newActive);
  });

  document.addEventListener("astro:after-swap", () => {
    const newActive = document
      .querySelector<HTMLElement>(".sheet.active")
      ?.dataset.sheet;
    if (newActive) setTargetSheet(newActive);
  });

  document.addEventListener("astro:page-load", attachSheetControls);
</script>
