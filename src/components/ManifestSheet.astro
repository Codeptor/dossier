---
import { getCollection } from "astro:content";
import Barcode from "@/components/Barcode.astro";
import DitherPanel from "@/components/DitherPanel.astro";
import MiniCli from "@/components/MiniCli.astro";
import Sparkline from "@/components/Sparkline.astro";
import { activity, artifacts, assets, capabilities, history, profile } from "@/data/profile";
import commits from "@/data/commits.json";

interface Commit {
  repo: string;
  sha: string;
  message: string;
  date: string;
}
const recentCommits: Commit[] = commits as Commit[];

interface Props {
  state: "active" | "left" | "right";
  route?: string;
}

const { state, route = "/" } = Astro.props;
const hasActivity = activity.some((v) => v > 0);
const thoughtCount = (await getCollection("thoughts")).length;
const stats = [
  { label: "ARTIFACTS", value: String(artifacts.length).padStart(2, "0") },
  { label: "THOUGHTS", value: String(thoughtCount).padStart(2, "0") },
  { label: "STACK", value: String(capabilities.length).padStart(2, "0") },
];
---

<article
  class:list={["sheet", "manifest-sheet", state]}
  data-sheet="manifest"
  data-route={route}
  transition:name="sheet-manifest"
>
  <div class="paper-grain"></div>
  <section class="manifest-head">
    <div>
      <h1>Operational<br />Manifest</h1>
      <p>Subject: {profile.name.toUpperCase()}</p>
      <p class="manifest-id">ID: {profile.id}</p>
      <div class="manifest-quicklinks">
        <a class="manifest-now" href="/now">NOW_LOG →</a>
        <a class="manifest-now" href="/pulse">PULSE →</a>
        <a class="manifest-now" href="/uses">USES →</a>
        <a class="manifest-now" href="/playlist">PLAYLIST →</a>
        <a class="manifest-now" href="/watching">WATCHING →</a>
        <a class="manifest-now" href="/reading">READING →</a>
        <a class="manifest-now" href="/contact">CONTACT →</a>
        <a class="manifest-now" href="/colophon">COLOPHON →</a>
      </div>
    </div>
    <DitherPanel />
  </section>

  <section class="status-grid">
    <div>
      <span>Status</span>
      <strong>{profile.status}</strong>
    </div>
    <div>
      <span>Location</span>
      <strong data-location>{profile.location}</strong>
    </div>
  </section>

  <div class="time-row">
    <span>Date: Wed, Apr 29, 2026</span>
    <span>Time: <time id="clock">--:--:--</time></span>
  </div>

  <section class="stat-row" aria-label="Dossier metrics">
    {stats.map((stat) => (
      <div class="stat-tile">
        <span>{stat.label}</span>
        <strong>{stat.value}</strong>
      </div>
    ))}
  </section>

  {hasActivity && (
    <section class="section-block">
      <h2>00 // Activity_Trace</h2>
      <div class="activity-card">
        <div class="activity-meta">
          <span>OUTPUT_INDEX</span>
          <em>last 6 mo</em>
        </div>
        <Sparkline data={activity} />
      </div>

      {recentCommits.length > 0 && (
        <div class="commit-ticker">
          <div class="commit-ticker-head">
            <span>RECENT_TRANSMISSIONS</span>
            <em>last {recentCommits.length} commits</em>
          </div>
          <ul>
            {recentCommits.slice(0, 6).map((c) => (
              <li>
                <code>{c.sha}</code>
                <strong>{c.repo}</strong>
                <span class="commit-msg">{c.message}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>
  )}

  <section class="section-block">
    <h2>01 // Profile_Summary</h2>
    <p class="quote">"{profile.summary}"</p>
  </section>

  <section class="section-block">
    <h2>02 // Operational_History</h2>
    <div class="timeline">
      {history.map((item) => (
        <div>
          <strong>{item.role}</strong>
          <span>{item.year}</span>
          <em>{item.org}</em>
        </div>
      ))}
    </div>
    <a class="dossier-link" href={profile.dossierHref}>Download_Full_Dossier.pdf <span>-></span></a>
  </section>

  <section class="section-block">
    <h2>03 // Deployed_Assets</h2>
    <div class="asset-list">
      {assets.map((asset) => (
        <a href={asset.href}>
          <strong>{asset.name}</strong>
          <span>{asset.description}</span>
          <em>{asset.href}</em>
        </a>
      ))}
    </div>
  </section>

  <section class="section-block">
    <h2>04 // Capability_Matrix</h2>
    <div class="capability-grid">
      {capabilities.map(([name, level]) => (
        <div>
          <span>{name}</span>
          <b>{level}</b>
        </div>
      ))}
    </div>
  </section>

  <section class="section-block">
    <h2>05 // Comm_Channels</h2>
    <div class="comm-grid">
      <a href={`mailto:${profile.email}`}>
        <span>✉</span>
        <strong>{profile.email}</strong>
      </a>
      {profile.socials.filter((s) => (s as any).primary).map((s) => (
        <a href={s.href} target="_blank" rel="me noreferrer noopener">
          <span>↗</span>
          <strong>{s.label}</strong>
        </a>
      ))}
    </div>
    <div class="comm-secondary">
      <span>ELSEWHERE</span>
      <div>
        {profile.socials.filter((s) => !(s as any).primary).map((s) => (
          <a href={s.href} target="_blank" rel="me noreferrer noopener">{s.label}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-block">
    <h2>06 // Terminal</h2>
    <MiniCli />
  </section>

  <footer class="manifest-foot">
    <div>
      <span>XP_TOTAL</span>
      <strong>TWO_PLUS_YEARS</strong>
    </div>
    <div>
      <span>{profile.revision}</span>
      <strong>[ OK ]</strong>
    </div>
    <div>
      <span>VISITS</span>
      <strong data-visit-count>001</strong>
    </div>
    <hr />
    <p>Manifest_End</p>
    <Barcode />
    <small>Stay_Curious</small>
  </footer>
</article>

<script>
  // Per-load setup: each astro:page-load brings the manifest back into the DOM
  // (or arrives fresh on first paint). Bind the clock once per arrival, clear
  // on swap so the prior interval doesn't pile up across navigations.
  let clockTimer: number | undefined;

  const startClock = () => {
    const clock = document.getElementById("clock");
    if (!clock) return;
    const tick = () => {
      clock.textContent = new Intl.DateTimeFormat("en-IN", {
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
        hour12: true,
      }).format(new Date());
    };
    tick();
    if (clockTimer !== undefined) window.clearInterval(clockTimer);
    clockTimer = window.setInterval(tick, 1000);
  };

  const stopClock = () => {
    if (clockTimer !== undefined) {
      window.clearInterval(clockTimer);
      clockTimer = undefined;
    }
  };

  // Location: visitor IP doesn't change mid-session — cache the resolved label
  // in sessionStorage so re-visits to the manifest don't re-hit the edge.
  const LOCATION_CACHE_KEY = "codeptor-visitor-location";

  const writeLocation = (label: string) => {
    document.querySelectorAll<HTMLElement>("[data-location]").forEach((el) => {
      el.textContent = label.toUpperCase();
    });
  };

  const setVisitorLocation = async () => {
    let cached: string | null = null;
    try {
      cached = sessionStorage.getItem(LOCATION_CACHE_KEY);
    } catch {
      /* sessionStorage unavailable — proceed without cache */
    }
    if (cached) {
      writeLocation(cached);
      return;
    }
    try {
      const res = await fetch("/api/location.json");
      if (!res.ok) return;
      const data = await res.json();
      if (data?.label) {
        const label = String(data.label);
        writeLocation(label);
        try {
          sessionStorage.setItem(LOCATION_CACHE_KEY, label);
        } catch {
          /* ignore */
        }
      }
    } catch {
      /* fall back to the static value already in the DOM */
    }
  };

  startClock();
  setVisitorLocation();
  document.addEventListener("astro:page-load", () => {
    startClock();
    setVisitorLocation();
  });
  document.addEventListener("astro:before-swap", stopClock);
</script>
