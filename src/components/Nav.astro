---
import { profile } from "@/data/profile";

interface Props {
  active: "home" | "thoughts" | "artifacts";
}

const { active } = Astro.props;
const nav = [
  { label: "home", href: "/", key: "1" },
  { label: "thoughts", href: "/thoughts", key: "2" },
  { label: "artifacts", href: "/artifacts", key: "3" },
];
---

<aside class="top-nav">
  <nav aria-label="Primary">
    <a class="brand" href="/" aria-label={`${profile.handle} home`}>
      <svg class="brand-mark" viewBox="0 0 13 13" aria-hidden="true">
        <g fill="currentColor">
          <rect x="6" y="0" width="1" height="3" />
          <rect x="6" y="10" width="1" height="3" />
          <rect x="0" y="6" width="3" height="1" />
          <rect x="10" y="6" width="3" height="1" />
          <rect x="5" y="5" width="3" height="3" />
        </g>
      </svg>
      <strong>{profile.handle}</strong>
    </a>
    <div class="nav-links">
      {nav.map((item) => (
        <a
          class:list={{ selected: active === item.label }}
          href={item.href}
          aria-keyshortcuts={item.key}
          title={`Press ${item.key}`}
        >
          {item.label}
          <kbd>{item.key}</kbd>
        </a>
      ))}
    </div>
    <button class="theme-toggle" type="button" aria-label="Cycle theme" data-theme-toggle>
      <span class="theme-tag">[ <em data-theme-name>DARK</em> ]</span>
    </button>
    <button class="audio-toggle" type="button" aria-label="Toggle sound" data-audio-toggle aria-pressed="false" data-muted="0">
      <span class="theme-tag">[ <em data-audio-label>MUTE</em> ]</span>
    </button>
  </nav>
</aside>

<nav class="mobile-nav" aria-label="Mobile">
  <div class="screen">
    <span>Current View</span>
    <strong>{active}</strong>
  </div>
  <div class="mobile-actions">
    {nav.map((item) => (
      <a class:list={{ selected: active === item.label }} href={item.href}>{item.label.slice(0, 1)}</a>
    ))}
  </div>
</nav>

<script>
  import { initAudio, isMuted, toggleMute, swap as swapSound, click as clickSound } from "@/lib/audio";

  const THEMES = ["dark", "blueprint", "plaque", "light"] as const;
  type Theme = (typeof THEMES)[number];
  const KEY = "codeptor-theme";

  const apply = (theme: Theme) => {
    document.documentElement.dataset.theme = theme;
    document.querySelectorAll<HTMLElement>("[data-theme-name]").forEach((el) => {
      el.textContent = theme.toUpperCase();
    });
  };

  const initial = ((): Theme => {
    try {
      const stored = localStorage.getItem(KEY);
      if (stored && (THEMES as readonly string[]).includes(stored)) return stored as Theme;
    } catch {}
    return "dark";
  })();
  apply(initial);

  initAudio();

  const reflectMute = () => {
    const m = isMuted();
    document.querySelectorAll<HTMLButtonElement>("[data-audio-toggle]").forEach((btn) => {
      btn.setAttribute("aria-pressed", m ? "true" : "false");
      btn.dataset.muted = m ? "1" : "0";
    });
    document.querySelectorAll<HTMLElement>("[data-audio-label]").forEach((el) => {
      el.textContent = m ? "UNMUTE" : "MUTE";
    });
  };
  reflectMute();

  const bind = () => {
    document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = "1";
      btn.addEventListener("click", () => {
        const current = (document.documentElement.dataset.theme || "dark") as Theme;
        const idx = THEMES.indexOf(current);
        const next = THEMES[(idx + 1) % THEMES.length];
        apply(next);
        try {
          localStorage.setItem(KEY, next);
        } catch {}
      });
    });

    document.querySelectorAll<HTMLButtonElement>("[data-audio-toggle]").forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = "1";
      btn.addEventListener("click", () => {
        toggleMute();
        reflectMute();
      });
    });

    // Delegated click sounds: real clicks on inactive sheets → swap;
    // any actionable <a>/<button> → click. Synthetic clicks dispatched
    // programmatically (e.g. DossierStack's link.click() relay) are ignored
    // via event.isTrusted so we don't double-trigger.
    if (!document.body.dataset.audioBound) {
      document.body.dataset.audioBound = "1";
      document.body.addEventListener("click", (event) => {
        if (!event.isTrusted) return;
        const target = event.target as HTMLElement | null;
        if (!target) return;

        const sheet = target.closest<HTMLElement>("[data-sheet][data-route]");
        if (sheet && !sheet.classList.contains("active")) {
          swapSound();
          return;
        }

        if (target.closest("a, button")) clickSound();
      });
    }
  };
  bind();
  document.addEventListener("astro:page-load", bind);

  // Keyboard shortcuts: 1/2/3 → routes, h/t/a → routes, ←/→ → prev/next, t → cycle theme
  const routeMap: Record<string, string> = {
    "1": "/",
    "h": "/",
    "2": "/thoughts",
    "3": "/artifacts",
    "a": "/artifacts",
  };
  const routes = ["/", "/thoughts", "/artifacts"];
  const currentRoute = (): string => {
    const path = location.pathname.replace(/\/$/, "") || "/";
    if (path.startsWith("/thoughts")) return "/thoughts";
    if (path.startsWith("/artifacts")) return "/artifacts";
    return routes.includes(path) ? path : "/";
  };
  const goTo = (route: string) => {
    if (route === currentRoute()) return;
    const link = document.querySelector<HTMLAnchorElement>(`a[href="${route}"]`);
    if (link) link.click();
    else location.href = route;
  };
  document.addEventListener("keydown", (event) => {
    if (event.metaKey || event.ctrlKey || event.altKey) return;
    const target = event.target as HTMLElement | null;
    if (target && (target.tagName === "INPUT" || target.tagName === "TEXTAREA" || target.isContentEditable)) return;
    const k = event.key.toLowerCase();
    if (k === "t") {
      document.querySelector<HTMLButtonElement>("[data-theme-toggle]")?.click();
      return;
    }
    if (routeMap[k]) {
      event.preventDefault();
      goTo(routeMap[k]);
      return;
    }
    if (event.key === "ArrowRight" || event.key === "ArrowLeft") {
      const dir = event.key === "ArrowRight" ? 1 : -1;
      const idx = routes.indexOf(currentRoute());
      const next = (idx + dir + routes.length) % routes.length;
      event.preventDefault();
      goTo(routes[next]);
    }
  });
</script>
