---
const pulsars = [
  { angle: -1.94, length: 92, bits: "1101001011" },
  { angle: -1.32, length: 78, bits: "10110100" },
  { angle: -0.71, length: 96, bits: "100101101" },
  { angle: -0.18, length: 88, bits: "1010111" },
  { angle: 0.34, length: 102, bits: "10010001011" },
  { angle: 0.83, length: 70, bits: "110011" },
  { angle: 1.42, length: 84, bits: "10101110" },
  { angle: 2.04, length: 98, bits: "1100101001" },
  { angle: 2.59, length: 74, bits: "1011001" },
  { angle: 3.05, length: 90, bits: "100110110" },
  { angle: -2.97, length: 80, bits: "1010110" },
  { angle: -2.52, length: 95, bits: "11010010" },
  { angle: -2.18, length: 68, bits: "11001" },
  { angle: 1.78, length: 86, bits: "10110011" },
];

const cx = 130;
const cy = 123;
---

<div class="plaque-panel" aria-hidden="true">
  <svg viewBox="0 0 260 246" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Pulsar reference plaque">
    <defs>
      <pattern id="plaqueGrid" width="13" height="13" patternUnits="userSpaceOnUse">
        <path d="M 13 0 L 0 0 0 13" fill="none" stroke="currentColor" stroke-width="0.4" opacity="0.18" />
      </pattern>
    </defs>

    <rect x="0.5" y="0.5" width="259" height="245" fill="url(#plaqueGrid)" stroke="currentColor" stroke-opacity="0.55" />

    <g stroke="currentColor" fill="none" opacity="0.5">
      <circle cx={cx} cy={cy} r="38" stroke-width="0.4" stroke-dasharray="2 3" />
      <circle cx={cx} cy={cy} r="64" stroke-width="0.3" stroke-dasharray="1 4" />
      <circle cx={cx} cy={cy} r="92" stroke-width="0.3" stroke-dasharray="1 6" opacity="0.6" />
    </g>

    <circle cx={cx} cy={cy} r="2.4" fill="currentColor" />
    <circle cx={cx} cy={cy} r="6" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.55" />

    {pulsars.map((p) => {
      const ex = cx + Math.cos(p.angle) * p.length;
      const ey = cy + Math.sin(p.angle) * p.length;
      const tickStep = 1.7;
      const tickHeight = 4;
      const perpX = -Math.sin(p.angle);
      const perpY = Math.cos(p.angle);
      const dirX = Math.cos(p.angle);
      const dirY = Math.sin(p.angle);
      const tickStart = 4;

      return (
        <g opacity="0.72">
          <line x1={cx} y1={cy} x2={ex} y2={ey} stroke="currentColor" stroke-width="0.6" />
          <circle cx={ex} cy={ey} r="1.4" fill="currentColor" />
          {p.bits.split("").map((bit, i) => {
            const tx = ex + dirX * (tickStart + i * tickStep);
            const ty = ey + dirY * (tickStart + i * tickStep);
            return bit === "1" ? (
              <line
                x1={tx - perpX * tickHeight * 0.5}
                y1={ty - perpY * tickHeight * 0.5}
                x2={tx + perpX * tickHeight * 0.5}
                y2={ty + perpY * tickHeight * 0.5}
                stroke="currentColor"
                stroke-width="0.7"
              />
            ) : null;
          })}
        </g>
      );
    })}

    <text x="8" y="14" font-family="ui-monospace, monospace" font-size="6" fill="currentColor" opacity="0.55" letter-spacing="1.4">
      PSR_INDEX // 14
    </text>
    <text x="252" y="14" text-anchor="end" font-family="ui-monospace, monospace" font-size="6" fill="currentColor" opacity="0.55" letter-spacing="1.4">
      H1_21CM
    </text>
    <text x="8" y="240" font-family="ui-monospace, monospace" font-size="6" fill="currentColor" opacity="0.55" letter-spacing="1.4">
      OBS // BHN0S.GAL
    </text>
    <text x="252" y="240" text-anchor="end" font-family="ui-monospace, monospace" font-size="6" fill="currentColor" opacity="0.55" letter-spacing="1.4">
      L:08+25 B:-04
    </text>
  </svg>
</div>
