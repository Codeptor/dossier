---
import { getCollection } from "astro:content";
import Barcode from "@/components/Barcode.astro";
import { profile } from "@/data/profile";

interface Props {
  state: "active" | "left" | "right";
  route?: string;
}

const { state, route = "/thoughts" } = Astro.props;

const entries = (await getCollection("thoughts")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const tagCounts = entries.reduce<Record<string, number>>((acc, t) => {
  acc[t.data.tag] = (acc[t.data.tag] ?? 0) + 1;
  return acc;
}, {});
const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
const totalEntries = entries.length;
const totalTags = Object.keys(tagCounts).length;
---

<article
  class:list={["sheet", "thoughts-sheet", state]}
  data-sheet="thoughts"
  data-route={route}
  transition:name="sheet-thoughts"
>
  <div class="paper-grain"></div>
  <div class="red-rule"></div>
  <header class="field-head">
    <div>
      <h1>Field Log</h1>
      <p>Issue 01 // 2026</p>
    </div>
    <div>
      <strong>Wed, Apr 29, 2026</strong>
      <span>Available now</span>
    </div>
  </header>

  <section class="field-stats" aria-label="Log metrics">
    <div class="field-stat">
      <span>ENTRIES</span>
      <strong>{String(totalEntries).padStart(2, "0")}</strong>
    </div>
    <div class="field-stat">
      <span>TAGS</span>
      <strong>{String(totalTags).padStart(2, "0")}</strong>
    </div>
    <div class="field-stat">
      <span>VOL</span>
      <strong>2026.01</strong>
    </div>
  </section>

  <p class="field-intro">
    Notes from the workbench: systems, markets, terminals, interfaces, and small tools that earn their place.
  </p>

  <section class="entries">
    <div class="entries-head">
      <h2>Selected Entries</h2>
      <span></span>
    </div>
    <div class="filters" role="tablist" aria-label="Filter by tag">
      <button class="filter-chip selected" data-filter="*" type="button">
        ALL · {totalEntries}
      </button>
      {tags.map(([tag, count]) => (
        <button class="filter-chip" data-filter={tag} type="button">
          {tag.toUpperCase()} · {count}
        </button>
      ))}
    </div>
    <div class="entry-list" data-entry-list>
      {entries.map((entry) => {
        const href = `/thoughts/${entry.id}`;
        const dateLabel = entry.data.date.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        });
        return (
          <a href={href} data-tag={entry.data.tag}>
            <div>
              <strong>{entry.data.title}</strong>
              <p>{entry.data.summary}</p>
              <em>{href}</em>
            </div>
            <time>{dateLabel}</time>
          </a>
        );
      })}
    </div>
  </section>

  <div class="field-stamp" aria-hidden="true">
    <div class="field-stamp-inner">
      <em>FILED</em>
      <strong>END_OF_LOG</strong>
      <span>BHN_CLR_A2 · {profile.year}</span>
    </div>
  </div>

  <footer class="field-foot">
    <p>{profile.name.toUpperCase()} // {profile.year}</p>
    <Barcode />
  </footer>
</article>

<script>
  const init = () => {
    const root = document.querySelector(".thoughts-sheet");
    if (!root) return;
    if (root.hasAttribute("data-filter-bound")) return;
    root.setAttribute("data-filter-bound", "1");

    const chips = root.querySelectorAll<HTMLButtonElement>(".filter-chip");
    const entries = root.querySelectorAll<HTMLAnchorElement>("[data-tag]");

    chips.forEach((chip) => {
      chip.addEventListener("click", (event) => {
        event.stopPropagation();
        const filter = chip.dataset.filter ?? "*";
        chips.forEach((c) => c.classList.toggle("selected", c === chip));
        entries.forEach((entry) => {
          const matches = filter === "*" || entry.dataset.tag === filter;
          entry.classList.toggle("hidden", !matches);
        });
      });
    });
  };
  init();
  document.addEventListener("astro:page-load", init);
</script>
