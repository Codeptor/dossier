  <div class="w-card" data-w-card data-w-state-id="nvim">
    <div class="w-tag">PLAYING A GAME</div>
    <div class="w-row">
      <div class="w-icon-box" data-w-icon-box>
        {states.map((s) => (
          <svg class={`w-icon-svg w-icon-svg-${s.id}`} viewBox="0 0 24 24" aria-hidden="true">
            <use href={`#w-i-${s.id}`} />
          </svg>
        ))}
        <span class="w-deafen" aria-hidden="true">
          <span></span>
        </span>
      </div>
      <div class="w-body">
        <strong>WezTerm</strong>
        <span class="w-state" data-w-state>Editing in Neovim</span>
        <span class="w-detail" data-w-detail>~/.config/wezterm | 1 tabs, 2 panes</span>
        <span class="w-elapsed" data-w-elapsed>02:14 elapsed</span>
      </div>
    </div>
  </div>
  <div class="w-meta">
    <span>OSC 1337 → STATE.JSON → IPC</span>
    <em data-w-source>nvim</em>
  </div>
</div>

<script define:vars={{ STATES: states }}>
  const init = () => {
    const card = document.querySelector("[data-w-card]");
    if (!card || card.dataset.bound) return;
    card.dataset.bound = "1";

    const iconBox = card.querySelector("[data-w-icon-box]");
    const stateEl = card.querySelector("[data-w-state]");
    const detailEl = card.querySelector("[data-w-detail]");
    const elapsedEl = card.querySelector("[data-w-elapsed]");
    const sourceEl = card
      .closest(".art-wezterm")
      ?.querySelector("[data-w-source]");

    let index = 1; // Neovim by default — matches initial markup
    let elapsed = 134;

    const apply = (i) => {
      const state = STATES[i];
      if (iconBox) {
        iconBox.style.background = state.bg;
        iconBox.style.color = state.fg;
      }
      card.dataset.wStateId = state.id;
      if (stateEl) stateEl.textContent = state.text;
      if (detailEl) detailEl.textContent = `${state.path} | ${state.tabs} tabs, ${state.panes} panes`;
      if (sourceEl) sourceEl.textContent = state.id;
    };

    const tick = () => {
      elapsed += 1;
      if (elapsedEl) {
        const m = String(Math.floor(elapsed / 60)).padStart(2, "0");
        const s = String(elapsed % 60).padStart(2, "0");
        elapsedEl.textContent = `${m}:${s} elapsed`;
      }
    };

    apply(index);

    const tickerId = window.setInterval(tick, 1000);
    const rotateId = window.setInterval(() => {
      index = (index + 1) % STATES.length;
      apply(index);
    }, 3500);

    const cleanup = () => {
      window.clearInterval(tickerId);
      window.clearInterval(rotateId);
    };
    document.addEventListener("astro:before-swap", cleanup, { once: true });
  };

  init();
  document.addEventListener("astro:page-load", init);
</script>
