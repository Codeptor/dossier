---
import { ClientRouter } from "astro:transitions";
import { profile } from "@/data/profile";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${profile.name} // ${profile.tagline}`,
  description = profile.summary,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://bhanueso.dev").toString();
const ogImage = new URL("/og.png", Astro.site ?? "https://bhanueso.dev").toString();

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  alternateName: profile.handle,
  url: Astro.site?.toString() ?? "https://bhanueso.dev",
  email: `mailto:${profile.email}`,
  description: profile.summary,
  jobTitle: "Creative Frontend Engineer",
  image: ogImage,
  sameAs: profile.socials.map((s) => s.href),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#080909" />
    <meta name="author" content={profile.name} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Field Log" href="/rss.xml" />
    <!-- Webmentions: register https://webmention.io with this domain to
         receive cross-site replies. Replace USER below once registered. -->
    <link rel="webmention" href="https://webmention.io/bhanueso.dev/webmention" />
    <link rel="pingback" href="https://webmention.io/bhanueso.dev/xmlrpc" />
    <script is:inline>
      // Apply the persisted theme synchronously before first paint, AND on
      // every Astro view-transition swap (the ClientRouter merges html
      // attributes from the new doc, which would otherwise wipe data-theme).
      // First-time visitors fall back to prefers-color-scheme.
      (function () {
        var KEY = "codeptor-theme";
        var THEMES = ["dark", "blueprint", "plaque", "light"];
        function resolve() {
          try {
            var t = localStorage.getItem(KEY);
            if (t && THEMES.indexOf(t) !== -1) return t;
          } catch (_) {}
          try {
            if (window.matchMedia && window.matchMedia("(prefers-color-scheme: light)").matches) {
              return "light";
            }
          } catch (_) {}
          return "dark";
        }
        function applyTo(root) {
          root.dataset.theme = resolve();
        }
        applyTo(document.documentElement);
        document.addEventListener("astro:before-swap", function (e) {
          if (e && e.newDocument) applyTo(e.newDocument.documentElement);
        });
      })();
    </script>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={profile.handle} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:creator" content="@esotericfrr" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(personLd)} />

    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <slot />

    <dialog class="shortcut-modal" data-shortcut-modal>
      <article>
        <header>
          <h2>Keyboard Shortcuts</h2>
          <button type="button" data-shortcut-close aria-label="Close">×</button>
        </header>
        <dl>
          <dt><kbd>1</kbd> / <kbd>h</kbd></dt><dd>Manifest (home)</dd>
          <dt><kbd>2</kbd></dt><dd>Field Log (thoughts)</dd>
          <dt><kbd>3</kbd> / <kbd>a</kbd></dt><dd>Archive (artifacts)</dd>
          <dt><kbd>←</kbd> <kbd>→</kbd></dt><dd>Cycle sheets</dd>
          <dt><kbd>t</kbd></dt><dd>Cycle theme</dd>
          <dt><kbd>?</kbd></dt><dd>Toggle this panel</dd>
          <dt><kbd>Esc</kbd></dt><dd>Close panel</dd>
        </dl>
        <footer>
          <span>// codeptor / dossier</span>
        </footer>
      </article>
    </dialog>

    <script>
      // Scale fixed-size iframe artifacts (1280x720 desktop renders) down to
      // their container width via a ResizeObserver. Avoids the cqi/transform
      // paint-timing race that left iframes unscaled until the user toggled zoom.
      const apply = (el: HTMLElement) => {
        const target = parseFloat(el.dataset.targetWidth || "1280");
        const w = el.getBoundingClientRect().width;
        if (w > 0 && target > 0) {
          el.style.setProperty("--frame-scale", String(w / target));
        }
      };
      const observed = new WeakSet<HTMLElement>();
      const ro = new ResizeObserver((entries) => {
        for (const e of entries) apply(e.target as HTMLElement);
      });
      const wire = () => {
        document.querySelectorAll<HTMLElement>("[data-scaled-frame]").forEach((el) => {
          if (!observed.has(el)) {
            observed.add(el);
            ro.observe(el);
          }
          apply(el);
          el.dataset.scaled = "1";
        });
      };
      wire();
      document.addEventListener("astro:page-load", wire);

      // Copy buttons on every code block. Adds a small button in the top-right
      // of each <pre>; click copies the inner text via the Clipboard API.
      const wireCopyButtons = () => {
        document.querySelectorAll<HTMLPreElement>(".reading-body pre").forEach((pre) => {
          if (pre.querySelector(".copy-btn")) return;
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "copy-btn";
          btn.textContent = "copy";
          btn.setAttribute("aria-label", "Copy code to clipboard");
          btn.addEventListener("click", async () => {
            const code = pre.querySelector("code")?.textContent ?? pre.textContent ?? "";
            try {
              await navigator.clipboard.writeText(code);
              btn.textContent = "copied";
              setTimeout(() => (btn.textContent = "copy"), 1500);
            } catch {
              btn.textContent = "error";
              setTimeout(() => (btn.textContent = "copy"), 1500);
            }
          });
          pre.appendChild(btn);
        });
      };
      wireCopyButtons();
      document.addEventListener("astro:page-load", wireCopyButtons);

      // Visitor counter — global total via the free abacus hit-counter API
      // (jasoncameron.dev). Increments once per browser session, then fetches
      // the running total on every page-load so all `[data-visit-count]`
      // slots stay in sync. Fails silently when offline; the DOM keeps its
      // "001" placeholder.
      const SESSION_KEY = "codeptor-visit-counted";
      const NAMESPACE = "bhanueso";
      const COUNTER = "dossier";
      const ENDPOINT = `https://abacus.jasoncameron.dev`;

      const renderVisits = (n: number) => {
        const text = String(n).padStart(3, "0");
        document.querySelectorAll<HTMLElement>("[data-visit-count]").forEach((el) => {
          el.textContent = text;
        });
      };

      const fetchVisits = async () => {
        let alreadyCounted = false;
        try {
          alreadyCounted = sessionStorage.getItem(SESSION_KEY) === "1";
        } catch {
          /* sessionStorage unavailable */
        }
        const path = alreadyCounted ? "get" : "hit";
        const url = `${ENDPOINT}/${path}/${NAMESPACE}/${COUNTER}`;
        try {
          const res = await fetch(url, { signal: AbortSignal.timeout(3000) });
          if (!res.ok) return;
          const data = await res.json();
          const value = typeof data?.value === "number" ? data.value : null;
          if (value === null) return;
          renderVisits(value);
          if (!alreadyCounted) {
            try {
              sessionStorage.setItem(SESSION_KEY, "1");
            } catch {
              /* ignore */
            }
          }
        } catch {
          /* offline / abacus down — leave the DOM placeholder alone */
        }
      };
      fetchVisits();
      document.addEventListener("astro:page-load", fetchVisits);

      // Help modal — `?` key toggles, Esc closes. The modal element is
      // re-queried every time so view-transition swaps don't leave us with
      // a stale reference.
      const wireModalChrome = () => {
        const modal = document.querySelector<HTMLDialogElement>("[data-shortcut-modal]");
        const closeBtn = document.querySelector<HTMLButtonElement>("[data-shortcut-close]");
        if (modal && !modal.dataset.bound) {
          modal.dataset.bound = "1";
          modal.addEventListener("click", (e) => {
            if (e.target === modal) modal.close();
          });
        }
        if (closeBtn && !closeBtn.dataset.bound) {
          closeBtn.dataset.bound = "1";
          closeBtn.addEventListener("click", () => {
            document.querySelector<HTMLDialogElement>("[data-shortcut-modal]")?.close();
          });
        }
      };
      wireModalChrome();
      document.addEventListener("astro:page-load", wireModalChrome);

      document.addEventListener("keydown", (e) => {
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        const target = e.target as HTMLElement | null;
        if (target && (target.tagName === "INPUT" || target.tagName === "TEXTAREA" || target.isContentEditable)) return;
        if (e.key === "?" || (e.shiftKey && e.key === "/")) {
          e.preventDefault();
          const modal = document.querySelector<HTMLDialogElement>("[data-shortcut-modal]");
          if (!modal) return;
          if (modal.open) modal.close();
          else modal.showModal();
        } else if (e.key === "Escape") {
          const modal = document.querySelector<HTMLDialogElement>("[data-shortcut-modal]");
          if (modal?.open) modal.close();
        }
      });
    </script>

    <script>
      // Vercel Analytics — privacy-friendly page-view tracking, free on hobby tier.
      import { inject } from "@vercel/analytics";
      inject();
    </script>
  </body>
</html>
