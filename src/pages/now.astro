---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Barcode from "@/components/Barcode.astro";
import { profile } from "@/data/profile";

export const prerender = false;

const LASTFM_USER = "esoterikunt";

async function getRecentTrack(): Promise<string | null> {
  const key = import.meta.env.LASTFM_API_KEY;
  if (!key) return null;
  const url =
    `https://ws.audioscrobbler.com/2.0/?method=user.getrecenttracks` +
    `&user=${LASTFM_USER}&api_key=${key}&format=json&limit=1`;
  try {
    const res = await fetch(url, {
      headers: { accept: "application/json" },
      signal: AbortSignal.timeout(2500),
    });
    if (!res.ok) return null;
    const data = await res.json();
    const track = data?.recenttracks?.track?.[0];
    if (!track) return null;
    const isNow = track["@attr"]?.nowplaying === "true";
    const name = track.name as string;
    const artist = track.artist?.["#text"] as string;
    if (!name || !artist) return null;
    const tag = isNow ? "now playing" : "last played";
    return `${name} — ${artist} · ${tag} · last.fm/${LASTFM_USER}`;
  } catch {
    return null;
  }
}

// Cache the page at the edge for 60s, serve stale up to 5min while revalidating.
Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=60, stale-while-revalidate=300",
);

const listening =
  (await getRecentTrack()) ??
  `last.fm/${LASTFM_USER} — set LASTFM_API_KEY to populate this row live.`;

const focus: { label: string; value: string }[] = [
  {
    label: "Building",
    value: "this dossier — three-sheet manifest with view-transition swaps and a real field log.",
  },
  {
    label: "Shipping",
    value: "Kharcha — public AI usage dashboard aggregating Claude Code, Codex, OpenCode, Kimi spend.",
  },
  {
    label: "Tinkering",
    value: "Astrolabe — Pioneer-plaque-style pulsar map, 14 pulsars selected by greedy GDOP.",
  },
  {
    label: "Writing",
    value: "field-log entries on view transitions, dithering, idempotent sync, and Rust audio threading.",
  },
  {
    label: "Reading",
    value: "\"Breasts and Eggs\" — Mieko Kawakami.",
  },
  {
    label: "Listening",
    value: listening,
  },
  {
    label: "Location",
    value: "India · IST.",
  },
  {
    label: "Open to",
    value: "freelance frontend / creative-coding work and full-time roles at small teams.",
  },
];
const updatedAt = "APR 30 2026";
---

<BaseLayout title="Now // Bhanu" description={`What ${profile.name} is focused on right now — building, shipping, reading, listening.`}>
  <Nav active="home" />
  <main class="now-shell">
    <article class="now-frame">
      <header class="now-head">
        <span>STATUS_REPORT</span>
        <h1>Now_Log</h1>
        <p>What I am focused on right now</p>
        <small>UPDATED {updatedAt}</small>
      </header>

      <section class="now-body">
        {focus.length === 0 ? (
          <div class="now-empty">
            <p>No current entries.</p>
            <p class="hint">// Drop a list of bullets in <code>src/pages/now.astro</code></p>
          </div>
        ) : (
          <ul>
            {focus.map((row) => (
              <li>
                <span>{row.label}</span>
                <strong>{row.value}</strong>
              </li>
            ))}
          </ul>
        )}
      </section>

      <footer class="now-foot">
        <a href="/">← Back to manifest</a>
        <Barcode />
      </footer>
    </article>
  </main>
</BaseLayout>

