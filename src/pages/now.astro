---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Barcode from "@/components/Barcode.astro";
import { profile } from "@/data/profile";
import { books } from "@/data/reading";

export const prerender = false;

const LASTFM_USER = "esoterikunt";
const LETTERBOXD_USER = "esoterikunt";

// ── Listening (Last.fm) ──
async function getRecentTrack(): Promise<string | null> {
  const key = import.meta.env.LASTFM_API_KEY;
  if (!key) return null;
  const url =
    `https://ws.audioscrobbler.com/2.0/?method=user.getrecenttracks` +
    `&user=${LASTFM_USER}&api_key=${key}&format=json&limit=1`;
  try {
    const res = await fetch(url, {
      headers: { accept: "application/json" },
      signal: AbortSignal.timeout(2500),
    });
    if (!res.ok) return null;
    const data = await res.json();
    const track = data?.recenttracks?.track?.[0];
    if (!track) return null;
    const isNow = track["@attr"]?.nowplaying === "true";
    const name = track.name as string;
    const artist = track.artist?.["#text"] as string;
    if (!name || !artist) return null;
    const tag = isNow ? "now playing" : "last played";
    return `${name} — ${artist} · ${tag} · last.fm/${LASTFM_USER}`;
  } catch {
    return null;
  }
}

// ── Watching (Letterboxd RSS) — pull most recent film with rating ──
const tag = (xml: string, name: string): string | null => {
  const match = xml.match(new RegExp(`<${name}[^>]*>([\\s\\S]*?)</${name}>`));
  return match ? match[1].trim() : null;
};
const cdata = (s: string | null): string =>
  s ? s.replace(/^<!\[CDATA\[/, "").replace(/\]\]>$/, "").trim() : "";

async function getLatestFilm(): Promise<string | null> {
  try {
    const res = await fetch(`https://letterboxd.com/${LETTERBOXD_USER}/rss/`, {
      headers: { "User-Agent": `${LETTERBOXD_USER}-dossier-runtime` },
      signal: AbortSignal.timeout(3500),
    });
    if (!res.ok) return null;
    const xml = await res.text();
    const blocks = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/g)];
    for (const m of blocks) {
      const block = m[1];
      const title = cdata(tag(block, "title")) || "";
      if (!title) continue;
      const cleanTitle = title.replace(/\s+-\s+★+½?$/, "").replace(/\s+-\s+½$/, "");
      const titleNoYear = cleanTitle.replace(/,\s*\d{4}$/, "").trim();
      const filmYear = cdata(tag(block, "letterboxd:filmYear")) || "";
      const ratingRaw = cdata(tag(block, "letterboxd:memberRating"));
      const rating = ratingRaw ? parseFloat(ratingRaw) : null;
      const stars = rating
        ? "★".repeat(Math.floor(rating)) + (rating % 1 >= 0.5 ? "½" : "")
        : "";
      const yearSuffix = filmYear ? ` (${filmYear})` : "";
      const ratingSuffix = stars ? ` · ${stars}` : "";
      return `${titleNoYear}${yearSuffix}${ratingSuffix} · letterboxd/${LETTERBOXD_USER}`;
    }
    return null;
  } catch {
    return null;
  }
}

// ── Reading (manual list, current entry) ──
const currentBook = books.find((b) => b.status === "current");
const readingValue = currentBook
  ? `"${currentBook.title}" — ${currentBook.author}${currentBook.note ? ` · ${currentBook.note}` : ""}`
  : "between books.";

// ── Latest blip + broadcast ──
const blips = (await getCollection("blips")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const broadcasts = (await getCollection("broadcasts"))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latestBlip = blips[0];
const latestBroadcast = broadcasts[0];

const latestBlipValue = latestBlip
  ? `"${latestBlip.data.title}" · /blips/${latestBlip.id}`
  : "—";
const latestBroadcastValue = latestBroadcast
  ? `"${latestBroadcast.data.title}" · /broadcasts/${latestBroadcast.id}`
  : "—";

// Cache the page at the edge for 60s, serve stale up to 5min while revalidating.
Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=60, stale-while-revalidate=300",
);

const listening = (await getRecentTrack()) ?? `last.fm/${LASTFM_USER}`;
const watching = (await getLatestFilm()) ?? `letterboxd/${LETTERBOXD_USER}`;

const focus: { label: string; value: string }[] = [
  {
    label: "Building",
    value: "this dossier — three-sheet manifest with view-transition swaps and a real field log.",
  },
  {
    label: "Shipping",
    value: "Kharcha — public AI usage dashboard aggregating Claude Code, Codex, OpenCode, Kimi spend.",
  },
  {
    label: "Tinkering",
    value: "Astrolabe — Pioneer-plaque-style pulsar map, 14 pulsars selected by greedy GDOP.",
  },
  {
    label: "Writing",
    value: latestBroadcastValue,
  },
  {
    label: "Latest blip",
    value: latestBlipValue,
  },
  {
    label: "Reading",
    value: readingValue,
  },
  {
    label: "Watching",
    value: watching,
  },
  {
    label: "Listening",
    value: listening,
  },
  {
    label: "Location",
    value: "India · IST.",
  },
  {
    label: "Open to",
    value: "freelance frontend / creative-coding work and full-time roles at small teams.",
  },
];
const updatedAt = "LIVE";
---

<BaseLayout title="Now // Bhanu" description={`What ${profile.name} is focused on right now — building, shipping, reading, listening.`}>
  <Nav active="home" />
  <main class="now-shell">
    <article class="now-frame">
      <header class="now-head">
        <span>STATUS_REPORT</span>
        <h1>Now_Log</h1>
        <p>What I am focused on right now</p>
        <small>UPDATED {updatedAt}</small>
      </header>

      <section class="now-body">
        {focus.length === 0 ? (
          <div class="now-empty">
            <p>No current entries.</p>
            <p class="hint">// Drop a list of bullets in <code>src/pages/now.astro</code></p>
          </div>
        ) : (
          <ul>
            {focus.map((row) => (
              <li>
                <span>{row.label}</span>
                <strong>{row.value}</strong>
              </li>
            ))}
          </ul>
        )}
      </section>

      <footer class="now-foot">
        <a href="/">← Back to manifest</a>
        <Barcode />
      </footer>
    </article>
  </main>
</BaseLayout>
