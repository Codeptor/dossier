---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Barcode from "@/components/Barcode.astro";
import { profile } from "@/data/profile";

export async function getStaticPaths() {
  const entries = (await getCollection("thoughts")).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
  );
  return entries.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: entries[i + 1] ?? null, // older entry
      next: entries[i - 1] ?? null, // newer entry
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const dateLabel = entry.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Reading time — body is the raw MDX source. ~200 wpm is a common
// average for technical reading.
const wordCount = entry.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));

const canonical = new URL(`/thoughts/${entry.id}/`, Astro.site ?? "https://bhanueso.dev").toString();
const ogImage = new URL(`/og.png?slug=${entry.id}`, Astro.site ?? "https://bhanueso.dev").toString();
const articleLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.summary,
  datePublished: entry.data.date.toISOString(),
  dateModified: entry.data.date.toISOString(),
  author: {
    "@type": "Person",
    name: profile.name,
    url: Astro.site?.toString() ?? "https://bhanueso.dev",
  },
  publisher: {
    "@type": "Person",
    name: profile.name,
  },
  url: canonical,
  image: ogImage,
  articleSection: entry.data.tag,
  wordCount,
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
};
---

<BaseLayout
  title={`${entry.data.title} // Field Log // Bhanu`}
  description={entry.data.summary}
>
  <Nav active="thoughts" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleLd)} />
  <div class="reading-progress" data-reading-progress aria-hidden="true">
    <div class="reading-progress-bar"></div>
  </div>
  <main class="reading-shell" data-reading-slug={entry.id}>
    <article class="reading-sheet">
      <header class="reading-head">
        <a href="/thoughts" class="reading-back">← Field Log</a>
        <h1>{entry.data.title}</h1>
        <div class="reading-meta">
          <time>{dateLabel}</time>
          <span>·</span>
          <em>{entry.data.tag}</em>
          <span>·</span>
          <em>{readingMinutes} min read</em>
        </div>
        <p class="reading-summary">{entry.data.summary}</p>
      </header>

      <aside class="reading-toc" data-reading-toc aria-label="Table of contents">
        <span>// CONTENTS</span>
        <ol></ol>
      </aside>

      <section class="reading-body" data-pagefind-body>
        <Content />
      </section>

      <nav class="reading-pager" aria-label="Field Log navigation">
        {prev ? (
          <a class="pager-link prev" href={`/thoughts/${prev.id}`}>
            <span>← Older</span>
            <strong>{prev.data.title}</strong>
          </a>
        ) : (
          <span class="pager-link disabled">
            <span>← Older</span>
            <strong>End of log</strong>
          </span>
        )}
        {next ? (
          <a class="pager-link next" href={`/thoughts/${next.id}`}>
            <span>Newer →</span>
            <strong>{next.data.title}</strong>
          </a>
        ) : (
          <span class="pager-link disabled">
            <span>Newer →</span>
            <strong>Latest entry</strong>
          </span>
        )}
      </nav>

      <footer class="reading-foot">
        <a href="/thoughts" class="reading-back">← Field Log</a>
        <Barcode />
        <p>{profile.name.toUpperCase()} // {profile.year}</p>
      </footer>
    </article>
  </main>

  <script>
    // Reading progress bar — pixel-thin top bar that tracks scroll inside
    // the reading-shell.
    const wireProgress = () => {
      const bar = document.querySelector<HTMLElement>("[data-reading-progress] .reading-progress-bar");
      if (!bar) return;
      const update = () => {
        const doc = document.documentElement;
        const max = doc.scrollHeight - doc.clientHeight;
        const pct = max > 0 ? Math.min(1, doc.scrollTop / max) : 0;
        bar.style.transform = `scaleX(${pct})`;
      };
      update();
      window.addEventListener("scroll", update, { passive: true });
      window.addEventListener("resize", update);
    };

    // TOC sidebar — auto-built from h2/h3 inside .reading-body. The headings
    // already have ids from rehype-slug.
    const wireToc = () => {
      const toc = document.querySelector<HTMLElement>("[data-reading-toc]");
      const list = toc?.querySelector("ol");
      const body = document.querySelector(".reading-body");
      if (!toc || !list || !body) return;
      const headings = body.querySelectorAll<HTMLElement>("h2[id], h3[id]");
      if (headings.length < 2) {
        toc.classList.add("empty");
        return;
      }
      while (list.firstChild) list.removeChild(list.firstChild);
      headings.forEach((h) => {
        const li = document.createElement("li");
        li.className = h.tagName.toLowerCase();
        const a = document.createElement("a");
        a.href = `#${h.id}`;
        a.textContent = h.textContent ?? "";
        li.appendChild(a);
        list.appendChild(li);
      });
    };

    // ✓ Read marker — once the visitor scrolls past the article middle,
    // remember they've read this entry so the field log list can dim it.
    const wireReadMarker = () => {
      const shell = document.querySelector<HTMLElement>("[data-reading-slug]");
      if (!shell) return;
      const slug = shell.dataset.readingSlug;
      if (!slug) return;
      let marked = false;
      const check = () => {
        if (marked) return;
        const doc = document.documentElement;
        const max = doc.scrollHeight - doc.clientHeight;
        if (max > 0 && doc.scrollTop / max > 0.4) {
          marked = true;
          try {
            const raw = localStorage.getItem("codeptor-read") || "[]";
            const arr = JSON.parse(raw) as string[];
            if (!arr.includes(slug)) {
              arr.push(slug);
              localStorage.setItem("codeptor-read", JSON.stringify(arr));
            }
          } catch {}
        }
      };
      check();
      window.addEventListener("scroll", check, { passive: true });
    };

    wireProgress();
    wireToc();
    wireReadMarker();
    document.addEventListener("astro:page-load", () => {
      wireProgress();
      wireToc();
      wireReadMarker();
    });
  </script>
</BaseLayout>
